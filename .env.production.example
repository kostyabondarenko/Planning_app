# ==============================================
# Production environment для Cloudflare Tunnel
# Скопировать в .env.production и заполнить
# .env.production НЕ коммитить в git
# ==============================================

# --- Домен и URL ---
DOMAIN=goalnavigator.ru
FRONTEND_URL=https://goalnavigator.ru
BACKEND_URL=https://api.goalnavigator.ru

# --- CORS (origin'ы, которым разрешён доступ к API) ---
# Через запятую, без пробелов, без trailing slash
CORS_ORIGINS=https://goalnavigator.ru

# --- PostgreSQL ---
POSTGRES_USER=planning_user
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=planning_db

# --- JWT / session secret ---
# Сгенерировать: openssl rand -hex 32
# Или в PowerShell: -join ((1..64) | ForEach-Object {'{0:x}' -f (Get-Random -Max 16)})
SECRET_KEY=CHANGE_ME_RUN_openssl_rand_hex_32

# --- Google OAuth (из плана 016) ---
# Создать в https://console.cloud.google.com/ → APIs & Services → Credentials
# Authorized redirect URI: https://api.goalnavigator.ru/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://api.goalnavigator.ru/auth/google/callback
